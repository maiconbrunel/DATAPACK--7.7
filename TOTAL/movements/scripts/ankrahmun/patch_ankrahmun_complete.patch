+-- [PROJECT 7.7 TFS 1.5] Converted script
+local COIN = 2159
+function onStepIn(creature, item, position)
+    if not creature or not creature:isPlayer() then return true end
+    local coinPos = Position(33276, 32553, 14)
+    local tpA = Position(33271, 32553, 14)
+    local tpB = Position(33277, 32553, 14)
+    local tile = Tile(coinPos)
+    local coinItem = tile and tile:getItemById(COIN) or nil
+    if item.actionid == 50120 and coinItem then
+        creature:teleportTo(tpA)
+        creature:getPosition():sendMagicEffect(CONST_ME_TELEPORT)
+        coinItem:remove(1)
+        coinPos:sendMagicEffect(CONST_ME_MAGIC_BLUE)
+    elseif item.actionid == 50121 then
+        creature:teleportTo(tpB)
+        creature:getPosition():sendMagicEffect(CONST_ME_TELEPORT)
+    end
+    return true
+end
