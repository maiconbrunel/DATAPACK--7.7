-- [PROJECT 7.7 TFS 1.5] Converted NPC
-- Purpose: Ahmet merchant NPC
-- Notes: Messages, keywords, and shop module preserved

local keywordHandler = KeywordHandler:new()
local npcHandler = NpcHandler:new(keywordHandler)
NpcSystem.parseParameters(npcHandler)

npcHandler:setMessage(MESSAGE_GREET, "Welcome |PLAYERNAME|! I got plenty of general equipments!")

local talk_state = 0

function onCreatureAppear(cid)         npcHandler:onCreatureAppear(cid)        end
function onCreatureDisappear(cid)      npcHandler:onCreatureDisappear(cid)     end
function onCreatureSay(cid, type, msg) npcHandler:onCreatureSay(cid, type, msg) end
function onThink()                      npcHandler:onThink()                     end
function onPlayerEndTrade(cid)         npcHandler:onPlayerEndTrade(cid)        end
function onPlayerCloseChannel(cid)     npcHandler:onPlayerCloseChannel(cid)    end

-- Keyword responses
function creatureSayCallback(cid, type, msg)
    if(npcHandler.focus ~= cid) then
        return false
    end

    if msgcontains(msg, 'quest') then
        npcHandler:say("I would advice a pick.")
    elseif msgcontains(msg, 'help') then
        npcHandler:say("I'm at your service, any items?")
    end

    return true
end

-- Shop Module
local shopModule = ShopModule:new()
npcHandler:addModule(shopModule)

-- Buyable Items
shopModule:addBuyableItem({'crowbar'},2416,260,'crowbar')
shopModule:addBuyableItem({'fishing rod','rod'},2580,150,'fishing rod')
shopModule:addBuyableItem({'backpack'},2004,10,'backpack')
shopModule:addBuyableItem({'pick'},2553,50,'pick')
shopModule:addBuyableItem({'rope'},2120,50,'rope')
shopModule:addBuyableItem({'scythe'},2550,50,'scythe')
shopModule:addBuyableItem({'shovel'},2554,10,'shovel')
shopModule:addBuyableItem({'worm'},3976,1,'worm')
shopModule:addBuyableItem({'oil'},2006,20,'oil')

-- Sellable Items
shopModule:addSellableItem({'rope'},2120,8,'rope')

npcHandler:setCallback(CALLBACK_MESSAGE_DEFAULT, creatureSayCallback)
npcHandler:addModule(FocusModule:new())
